{
  "name": "aicoursenote",
  "private": true,
  "version": "0.1.0",
  "author": "AICourseNote",
  "description": "AI-assisted desktop course note assistant",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist:win": "npm run build && electron-builder --win portable",
    "dist:dir": "npm run build && electron-builder --win dir",
    "dist:local": "npm run dist:dir && node scripts/local-installer/build-local-installer.mjs",
    "preview": "electron-vite preview",
    "start": "electron .",
    "start:direct": "node_modules/electron/dist/electron.exe .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@tiptap/extension-color": "^2.27.2",
    "@tiptap/extension-highlight": "^2.27.2",
    "@tiptap/extension-image": "^2.11.5",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-table": "^2.27.2",
    "@tiptap/extension-table-cell": "^2.27.2",
    "@tiptap/extension-table-header": "^2.27.2",
    "@tiptap/extension-table-row": "^2.27.2",
    "@tiptap/extension-text-style": "^2.27.2",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "dayjs": "^1.11.13",
    "keytar": "^7.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sanitize-html": "^2.17.1",
    "sql.js": "^1.14.1",
    "uuid": "^11.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.3",
    "vite": "^5.4.14"
  },
  "build": {
    "appId": "com.aicoursenote.desktop",
    "copyright": "Copyright (c) AICourseNote",
    "productName": "AICourseNote",
    "asar": true,
    "asarUnpack": [
      "node_modules/sql.js/dist/*.wasm"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "build/**/*",
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "extraMetadata": {
      "main": "out/main/main.js"
    }
  }
}
